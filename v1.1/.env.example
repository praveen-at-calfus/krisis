# Copy this to the project root as `.env` (shared across all versions) and fill in real values.
#   cp v1.1/.env.example .env   # then edit

# Required — your OpenAI API key
OPENAI_API_KEY=sk-your-key-here

# Optional (defaults shown)
DATABASE_URL=postgresql+psycopg://localhost:5432/krisis
MODEL=gpt-4o-mini
MAX_TICKET_CHARS=8000
MANUAL_TRIAGE_SECONDS=300
